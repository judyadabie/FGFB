<main class="blog-detail-page">
    <section class="page__title-area">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xxl-10 col-xl-10 col-lg-10">
                    <div class="page__title-wrapper text-center">
                        <h1 class="page__title-2">@title</h1>

                        <div class="blog__date blog__date-2 d-flex align-items-center justify-content-center blog__top-date">
                            <i class="fal fa-clock mr-10"></i>
                            <span>@createdDate</span>
                        </div>

                        @if (!string.IsNullOrEmpty(headerImageUrl))
                        {
                            <div class="blog__detail-image-wrap">
                                <img src="@headerImageUrl" alt="@title" class="blog__detail-image" />

                                <div class="blog__image-author-card">
                                    <img src="@authorImageUrl" alt="@authorName" class="blog__author-avatar" />
                                    <div class="blog__image-author-text">
                                        <span class="blog__image-author-label">Written by</span>
                                        <h5>@authorName</h5>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="blog__author-below d-flex align-items-center justify-content-center">
                                <img src="@authorImageUrl" alt="@authorName" class="blog__author-avatar" />
                                <div class="blog__image-author-text">
                                    <span class="blog__image-author-label">Written by</span>
                                    <h5>@authorName</h5>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="blog__area">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xxl-8 col-xl-8 col-lg-9">
                    <div class="blog__wrapper">
                        <div class="blog__text">
                            @Html.Raw(RenderRichText(fields?.BlogBody, includes))
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

