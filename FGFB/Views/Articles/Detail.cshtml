@functions {
    public string RenderRichText(RichTextDocument? document, Includes? includes)
    {
        if (document?.Content == null) return string.Empty;
        return string.Join("", document.Content.Select(x => RenderNode(x, includes)));
    }

    public string RenderNode(RichTextNode? node, Includes? includes)
    {
        if (node == null) return string.Empty;

        if (node.NodeType == "text")
        {
            return ApplyMarks(node.Value ?? string.Empty, node.Marks);
        }

        if (node.NodeType == "embedded-asset-block")
        {
            return RenderEmbeddedAsset(node, includes);
        }

        var inner = node.Content == null
            ? string.Empty
            : string.Join("", node.Content.Select(x => RenderNode(x, includes)));

        return node.NodeType switch
        {
            "paragraph" => $"<p>{inner}</p>",
            "heading-1" => $"<h1>{inner}</h1>",
            "heading-2" => $"<h2>{inner}</h2>",
            "heading-3" => $"<h3>{inner}</h3>",
            "unordered-list" => $"<ul>{inner}</ul>",
            "ordered-list" => $"<ol>{inner}</ol>",
            "list-item" => $"<li>{inner}</li>",
            "hr" => "<hr>",
            "hyperlink" => BuildLink(node, inner),
            _ => inner
        };
    }

    public string ApplyMarks(string text, List<Mark>? marks)
    {
        if (marks == null || !marks.Any()) return text;

        foreach (var mark in marks)
        {
            text = mark.Type switch
            {
                "bold" => $"<strong>{text}</strong>",
                "italic" => $"<em>{text}</em>",
                "underline" => $"<u>{text}</u>",
                _ => text
            };
        }

        return text;
    }

    public string BuildLink(RichTextNode node, string inner)
    {
        if (node.Data != null &&
            node.Data.TryGetValue("uri", out JsonElement uriElement) &&
            uriElement.ValueKind == JsonValueKind.String)
        {
            var uri = uriElement.GetString();
            return $"<a target=\"_blank\" rel=\"noopener noreferrer\" class=\"mylinks\" href=\"{uri}\">{inner}</a>";
        }

        return inner;
    }

    public string RenderEmbeddedAsset(RichTextNode node, Includes? includes)
    {
        if (node.Data == null ||
            !node.Data.TryGetValue("target", out JsonElement targetElement) ||
            !targetElement.TryGetProperty("sys", out JsonElement sysElement) ||
            !sysElement.TryGetProperty("id", out JsonElement idElement))
        {
            return string.Empty;
        }

        var assetId = idElement.GetString();
        if (string.IsNullOrEmpty(assetId)) return string.Empty;

        var asset = includes?.Asset?.FirstOrDefault(a => a.Sys?.Id == assetId);
        if (asset?.Fields?.File?.Url == null) return string.Empty;

        var url = $"https:{asset.Fields.File.Url}";
        var alt = asset.Fields.Title ?? "";
        return $"<img class=\"blog-content-image\" src=\"{url}\" alt=\"{alt}\">";
    }
}