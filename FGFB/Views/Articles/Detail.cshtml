@model FGFB.Models.Item
@using FGFB.Models
@using System.Text.Json

@{
    Layout = "_Layout";
    var fields = Model.Fields;
    var includes = ViewBag.Includes as Includes;

    var title = fields?.Title ?? "";
    var createdDate = Model.Sys?.CreatedAt?.ToString("MMMM dd, yyyy") ?? "";

    ViewData["Title"] = title;
    ViewData["MetaDescription"] = title;
    ViewData["MetaKeywords"] = title;

    var headerImageId = fields?.HeaderImage?.Sys?.Id ?? fields?.Thumbnail?.Sys?.Id;
    var headerImage = includes?.Asset?.FirstOrDefault(a => a.Sys?.Id == headerImageId);
    var headerImageUrl = headerImage?.Fields?.File?.Url != null
        ? $"https:{headerImage.Fields.File.Url}"
        : "/img/blog/TaylorSwift.png";

    var authorId = fields?.Author?.Sys?.Id;
    var author = includes?.Entry?.FirstOrDefault(e => e.Sys?.Id == authorId);
    var authorName = !string.IsNullOrWhiteSpace(author?.Fields?.Name) ? author.Fields.Name : "Fan Girl Football";
    var authorImageId = author?.Fields?.Picture?.Sys?.Id;

    var authorImage = includes?.Asset?.FirstOrDefault(a => a.Sys?.Id == authorImageId);
    var authorImageUrl = authorImage?.Fields?.File?.Url != null
        ? $"https:{authorImage.Fields.File.Url}"
        : "/img/default-author.png";
}

