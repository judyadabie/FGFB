@model FGFB.Models.LeagueJoinViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "League Payment";

    var entryFee = Model.EntryFee ?? 0m;
    var processingFee = Math.Round((entryFee * 0.03m) + 0.30m, 2);
    var total = entryFee + processingFee;
}

<link rel="stylesheet" href="~/css/leagues-flow.css" asp-append-version="true" />



<div class="leagues-flow-page">
    <div class="leagues-flow-card">
        <h1 class="leagues-flow-title">Continue to Complete Payment</h1>
        <p class="leagues-flow-subtitle">
            Your Fan Girl Football email was validated successfully.
        </p>

        <div class="leagues-flow-details">
            <div class="leagues-flow-label">League Type</div>
            <div class="leagues-flow-value">@Model.LeagueType</div>

            <div class="leagues-flow-label">Entry Fee</div>
            <div class="leagues-flow-value">@entryFee.ToString("C")</div>

            <div class="leagues-flow-label">Processing Fee</div>
            <div class="leagues-flow-value">@processingFee.ToString("C")</div>

            <div class="leagues-flow-label">Total</div>
            <div class="leagues-flow-value">@total.ToString("C")</div>

            <div class="leagues-flow-label">Draft Date</div>
            <div class="leagues-flow-value">
                @(Model.DraftDate.HasValue
                    ? Model.DraftDate.Value.ToString("MMMM dd, yyyy h:mm tt")
                    : "TBD")
            </div>

            <div class="leagues-flow-label">Member Email</div>
            <div class="leagues-flow-value">@Model.Email</div>
        </div>

        <hr class="leagues-flow-divider" />

        <p class="leagues-flow-note">
            Continue to secure checkout to complete your signup.
        </p>

        <form asp-controller="Leagues" asp-action="CreateStripeCheckout" method="post" class="leagues-flow-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="leagueId" value="@Model.LeagueId" />
            <input type="hidden" name="email" value="@Model.Email" />

            <div class="leagues-flow-actions">
                <button type="submit" class="leagues-flow-button">
                    Continue to Checkout
                </button>
            </div>
        </form>
    </div>
</div>

@await Html.PartialAsync("_SiteFooter")