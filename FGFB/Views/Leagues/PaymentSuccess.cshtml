@model FGFB.Models.LeaguePaymentSuccessViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Leagues";
    ViewData["MetaDescription"] = "Browse Fan Girl Football leagues and join the one that fits you best.";
    ViewData["MetaKeywords"] = "fantasy football leagues, Fan Girl Football, women fantasy football leagues, wbna leagues";
}

<style>
    .payment-success-wrap {
        max-width: 820px;
        margin: 60px auto;
        padding: 0 20px;
    }

    .payment-success-card {
        background: #fff;
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        padding: 40px 32px;
    }

    .payment-success-title {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 10px;
        text-align: center;
    }

    .payment-success-subtitle {
        text-align: center;
        font-size: 1.05rem;
        color: #555;
        margin-bottom: 30px;
    }

    .payment-success-status {
        text-align: center;
        font-size: 1rem;
        margin-bottom: 30px;
        color: #444;
    }

    .payment-success-grid {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 14px 18px;
        margin: 30px 0;
        align-items: start;
    }

    .payment-success-label {
        font-weight: 700;
        color: #222;
    }

    .payment-success-value {
        color: #444;
    }

    .payment-success-divider {
        margin: 30px 0;
        border: 0;
        border-top: 1px solid #e5e5e5;
    }

    .payment-success-actions {
        text-align: center;
        margin-top: 30px;
    }

    .league-link-button {
        display: inline-block;
        background: #111;
        color: #fff !important;
        text-decoration: none;
        font-weight: 700;
        font-size: 1rem;
        padding: 14px 26px;
        border-radius: 999px;
        transition: all 0.2s ease;
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    }

        .league-link-button:hover {
            background: #333;
            transform: translateY(-1px);
        }

    .payment-success-note {
        margin-top: 18px;
        text-align: center;
        color: #666;
        font-size: 0.95rem;
    }

    @@media (max-width: 640px) {
        .payment-success-card

    {
        padding: 28px 20px;
    }

    .payment-success-grid {
        grid-template-columns: 1fr;
        gap: 6px 0;
    }

    .payment-success-label {
        margin-top: 10px;
    }

    }
</style>



<div id="loading">
    <div id="loading-center">
        <div id="loading-center-absolute">
            <div class="loading-content">
                <img class="loading-logo-text" src="~/img/logo/FGFLogoNewFont.png" alt="Fan Girl Football">
                <div class="loading-stroke">
                    <img class="loading-logo-icon" src="~/img/shape/hero/football.png" alt="Fan Girl Football">
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_SiteHeader")
<main class="league-page">
    <section class="league-hero">
        <div class="container">
<div class="payment-success-wrap">
    <div class="payment-success-card">
        <h1 class="payment-success-title">You're In!</h1>

        @if (Model.PaymentStatus == "Processing")
        {
            <p class="payment-success-subtitle">
                Your payment is still being processed.
            </p>

            <p class="payment-success-status">
                Please refresh this page in a moment.
            </p>
        }
        else
        {
            <p class="payment-success-subtitle">
                Your payment was successful and your spot is secured.
            </p>

            <div class="payment-success-grid">
                <div class="payment-success-label">League Type</div>
                <div class="payment-success-value">@Model.LeagueType</div>

                <div class="payment-success-label">Entry Fee</div>
                <div class="payment-success-value">
                    @(Model.EntryFee.HasValue? Model.EntryFee.Value.ToString("C") : "N/A")
                </div>

                <div class="payment-success-label">Draft Date</div>
                <div class="payment-success-value">
                    @(Model.DraftDate.HasValue? Model.DraftDate.Value.ToString("MMMM dd, yyyy h:mm tt") : "TBD")
                </div>

                <div class="payment-success-label">Email</div>
                <div class="payment-success-value">@Model.Email</div>
            </div>

            <hr class="payment-success-divider" />

            @if (!string.IsNullOrWhiteSpace(Model.LeagueLink))
            {
                <div class="payment-success-actions">
                    <a href="@Model.LeagueLink" target="_blank" rel="noopener" class="league-link-button">
                        Access Your League
                    </a>
                </div>
            }

            <p class="payment-success-note">
                You should also receive an email with your league details.
            </p>
        }
    </div>
</div>
</div></section>
</main>
@await Html.PartialAsync("_SiteFooter")
