        font-size: 16px;
        font-weight: 700;
        margin-bottom: 6px;
        color: #111;
    }
    .league-info-steps {
        padding-left: 18px;
        margin-bottom: 0;
    }

        .league-info-steps li {
            margin-bottom: 10px;
            line-height: 1.5;
        }

    .league-info-links ul {
        padding-left: 18px;
        margin-bottom: 0;
    }

    .league-info-links li {
        margin-bottom: 6px;
    }
    .league-info-heading {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 0;
        color: #111;
    }

    .league-info-divider {
        border: 0;
        border-top: 1px solid #ddd;
        margin: 18px 0;
        opacity: 1;
    }

    .league-prizes-table {
        margin-bottom: 0;
    }

