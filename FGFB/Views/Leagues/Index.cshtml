            border: 1px solid #e9e9e9;
            text-align: left;
            vertical-align: middle;
            font-size: 14px;
        }

        .league-prizes-table thead th {
            background: #f8f8f8;
            font-weight: 700;
            color: #111;
        }

    .league-info-content p {
        margin-bottom: 0;
    }
    .site-header-solid,
    .site-header-solid.sticky {
        background: #fff !important;
        border-bottom: 1px solid #e8e8e8 !important;
