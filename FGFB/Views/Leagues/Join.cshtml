@model FGFB.Models.LeagueJoinViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Join League";
}

@await Html.PartialAsync("_SiteHeader")

<main class="league-page">
    <section class="league-hero">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="join-card">
                        <h1 class="page__title-2 join-title">Join League</h1>

                        <div class="join-league-info">
                            <div class="join-info-row">
                                <span class="join-info-label">League Type</span>
                                <span class="join-info-value">@Model.LeagueType</span>
                            </div>

                            <div class="join-info-row">
                                <span class="join-info-label">Entry Fee</span>
                                <span class="join-info-value">@(Model.EntryFee.HasValue? Model.EntryFee.Value.ToString("C") : "Free")</span>
                            </div>

                            <div class="join-info-row">
                                <span class="join-info-label">Draft Date</span>
                                <span class="join-info-value">@(Model.DraftDate.HasValue? Model.DraftDate.Value.ToString("MMMM dd, yyyy h:mm tt") : "TBD")</span>
                            </div>
                        </div>

                        <p class="join-help-text">
                            Enter the email address you used to register with Fan Girl Football.
                            This email must match your Fan Girl Football member email address.
                        </p>

                        <p class="join-help-text">
                            Not a member yet?
                            <a href="https://fan-girl-football.mn.co/sign_up"
                               target="_blank"
                               rel="noopener noreferrer"
                               class="signup-link">
                                Sign up for free
                            </a>
                        </p>

                        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                        {
                            <div class="join-error">
                                @Html.Raw(Model.ErrorMessage)
                            </div>
                        }
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        <form asp-action="Join" asp-controller="Leagues" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="LeagueId" />

                            <div class="form-group mb-20">
                                <label asp-for="Email" class="join-label"></label>
                                <input asp-for="Email" class="join-input" placeholder="you@example.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <button type="submit" class="league-join-btn league-join-btn--full">
                                Continue
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

@await Html.PartialAsync("_SiteFooter")

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>

    /* Error container */
    .join-error {
        background: #f8f5ff;
        border: 1px solid #e6dcff;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
        text-align: center;
    }

    /* Inner layout */
    .join-error-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
    }

    /* Title */
    .join-error-title {
        font-weight: 700;
        font-size: 18px;
        color: #3a1fa3;
    }

    /* Supporting text */
    .join-error-text {
        font-size: 14px;
        color: #555;
        max-width: 320px;
    }

    /* CTA button */
    .join-error-cta {
        display: inline-block;
        margin-top: 10px;
        background: #e6dcff;
        color: #4b2bbd;
        padding: 12px 22px;
        border-radius: 999px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s ease;
        box-shadow: 0 6px 16px rgba(123, 97, 255, 0.2);
    }

        /* Hover */
        .join-error-cta:hover {
            background: #d4c6ff;
            color: #3a1fa3;
            transform: translateY(-1px);
        }

    /* Mobile */
    @@media (max-width: 767px) {
        .join-error

    {
        padding: 16px;
    }

    .join-error-title {
        font-size: 16px;
    }

    }
    /* Pill + light purple button */
    .league-join-btn {
        background: #d9ccff;
        color: #3a1fa3;
        ; /* darker purple text */
        border: none;
        border-radius: 999px; /* pill shape */
        padding: 14px 26px;
        font-weight: 600;
        font-size: 16px;
        text-align: center;
        display: inline-block;
        transition: all 0.25s ease;
        box-shadow: 0 6px 16px rgba(123, 97, 255, 0.2);
    }

    .signup-link-error {
        display: inline-block;
        background: #e6dcff;
        color: #4b2bbd;
        padding: 10px 18px;
        border-radius: 999px;
        font-weight: 700;
        text-decoration: none;
        margin-top: 10px;
        transition: all 0.2s ease;
    }

        .signup-link-error:hover {
            background: #d4c6ff;
            color: #3a1fa3;
        }

    /* Hover effect */
    .league-join-btn:hover {
        background: #d4c6ff;
        color: #3a1fa3;
        text-decoration: none;
    }

    /* Active click */
    .league-join-btn:active {
        transform: scale(0.98);
    }
    .signup-link {
    color: #6c4cff; /* purple */
    font-weight: 700;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: all 0.2s ease;
}

.signup-link:hover {
    color: #4b2bbd;
    border-bottom: 2px solid #4b2bbd;
}
    .league-page .page__title-2 {
