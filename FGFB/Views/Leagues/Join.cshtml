@model FGFB.Models.LeagueJoinViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Join League";

    var entryFeeText = Model.EntryFee.HasValue
        ? Model.EntryFee.Value.ToString("C")
        : "Free";

    var draftDateText = Model.DraftDate.HasValue
        ? Model.DraftDate.Value.ToString("MMMM dd, yyyy h:mm tt")
        : "TBD";
}

<link rel="stylesheet" href="~/css/leagues-flow.css" asp-append-version="true" />

@await Html.PartialAsync("_SiteHeader")

<div class="leagues-flow-page">
    <div class="leagues-flow-card">
        <h1 class="leagues-flow-title">Join League</h1>
        <p class="leagues-flow-subtitle">
            Enter the email address you used to register with Fan Girl Football.
            This must match your Fan Girl Football member email address.
        </p>

        <div class="leagues-flow-details">
            <div class="leagues-flow-label">League Type</div>
            <div class="leagues-flow-value">@Model.LeagueType</div>

            <div class="leagues-flow-label">Entry Fee</div>
            <div class="leagues-flow-value">@entryFeeText</div>

            <div class="leagues-flow-label">Draft Date</div>
            <div class="leagues-flow-value">@draftDateText</div>
        </div>

        <hr class="leagues-flow-divider" />

        <p class="leagues-flow-note">
            Not a member yet?
            <a href="https://fan-girl-football.mn.co/" target="_blank" rel="noopener">
                Sign up for free
            </a>
        </p>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="leagues-flow-status">
                @Html.Raw(Model.ErrorMessage)
            </div>
        }

        <form asp-controller="Leagues" asp-action="Join" method="post" class="leagues-flow-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="LeagueId" />
            <input type="hidden" asp-for="LeagueType" />
            <input type="hidden" asp-for="EntryFee" />
            <input type="hidden" asp-for="DraftDate" />

            <div class="form-group" style="margin-bottom: 20px;">
                <label asp-for="Email" class="leagues-flow-label" style="display:block; margin-bottom:8px;">Email Address</label>
                <input asp-for="Email" class="form-control" style="width:100%; max-width:100%; padding:12px 14px; border:1px solid #d9d9d9; border-radius:14px;" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="leagues-flow-actions">
                <button type="submit" class="leagues-flow-button">
                    Continue
                </button>
            </div>
        </form>
    </div>
</div>

@await Html.PartialAsync("_SiteFooter")

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}