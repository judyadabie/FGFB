@model FGFB.Models.CommishLoginViewModel

@{
    ViewData["Title"] = "Commish Login";
}
 <link rel="shortcut icon" type="image/x-icon" href="/img/favicon.png">
<style>
    .commish-login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 16px;
        background: linear-gradient(135deg, #12081f 0%, #2b1247 45%, #6f42c1 100%);
    }

    .commish-login-shell {
        width: 100%;
        max-width: 520px;
        margin: 0 auto;
    }

    .commish-login-card {
        border: 0;
        border-radius: 26px;
        overflow: hidden;
        background: rgba(255,255,255,0.98);
        box-shadow: 0 25px 70px rgba(0, 0, 0, 0.25);
    }

    .commish-login-top {
        padding: 34px 28px 24px;
        text-align: center;
        background: linear-gradient(135deg, #6f42c1 0%, #a855f7 100%);
        color: #fff;
    }

        .commish-login-top h1 {
            margin: 0 0 8px;
            font-size: 2rem;
            font-weight: 800;
        }

        .commish-login-top p {
            margin: 0;
            opacity: 0.94;
        }

    .commish-login-body {
        padding: 32px 32px 30px;
    }

    .commish-form-group {
        margin-bottom: 20px;
    }

        .commish-form-group:last-of-type {
            margin-bottom: 26px;
        }

    .commish-label {
        display: block;
        font-weight: 700;
        color: #2b1247;
        margin-bottom: 8px;
    }

    .commish-input {
        display: block;
        width: 100%;
        height: 54px;
        border-radius: 14px;
        border: 1px solid #d9c9f3;
        padding: 0 16px;
        font-size: 1rem;
        box-sizing: border-box;
    }

        .commish-input:focus {
            border-color: #8b5cf6;
            box-shadow: 0 0 0 0.2rem rgba(139, 92, 246, 0.18);
        }

    .commish-validation {
        display: block;
        margin-top: 6px;
        min-height: 18px;
        font-size: 0.85rem;
    }

    .commish-login-btn {
        display: block;
        width: 100%;
        height: 56px;
        border: 0;
        border-radius: 999px;
        font-weight: 700;
        font-size: 1rem;
        background: linear-gradient(135deg, #6f42c1 0%, #a855f7 100%);
        color: #fff;
        box-shadow: 0 10px 24px rgba(111, 66, 193, 0.28);
        margin-top: 4px;
    }

        .commish-login-btn:hover {
            color: #fff;
        }

    .commish-login-note {
        margin-top: 18px;
        text-align: center;
        color: #6b7280;
        font-size: 0.92rem;
    }

    @@media (max-width: 575.98px) {
        .commish-login-top h1 {
            font-size: 1.7rem;
        }

        .commish-login-top,
        .commish-login-body {
            padding-left: 20px;
            padding-right: 20px;
        }
    }
</style>

<div class="commish-login-page">
    <div class="commish-login-shell">
        <div class="card commish-login-card">
            <div class="commish-login-top">
                <h1>Commish Portal</h1>
                <p>View current event and league registrations</p>
            </div>

            <div class="commish-login-body">
                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-danger rounded-4 mb-4">
                        @Model.ErrorMessage
                    </div>
                }

                <form asp-action="Login" asp-controller="Commish" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReturnUrl" />

                    <div class="commish-form-group">
                        <label asp-for="Email" class="commish-label"></label>
                        <input asp-for="Email" class="form-control commish-input" autocomplete="username" />
                        <span asp-validation-for="Email" class="text-danger commish-validation"></span>
                    </div>

                    <div class="commish-form-group">
                        <label asp-for="Password" class="commish-label"></label>
                        <input asp-for="Password" class="form-control commish-input" autocomplete="current-password" />
                        <span asp-validation-for="Password" class="text-danger commish-validation"></span>
                    </div>

                    <button type="submit" class="btn commish-login-btn">
                        Log In
                    </button>
                </form>

                <div class="commish-login-note">
                    Fan Girl Football admin access
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}