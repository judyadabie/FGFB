@model FGFB.Models.ChampionshipDraftWeekendSignupViewModel
@{
    Layout = null;
    ViewData["Title"] = "Championship Draft Weekend Sign Up";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/championship-draft-weekend-signup.css" asp-append-version="true" />
    <link rel="shortcut icon" type="image/x-icon" href="/img/favicon.png">
</head>

<body>
    <div class="container page">
        <div class="topbar">
            <a href="@Url.Action("ChampionshipDraftWeekend", "Events")" class="btn btn-outline">← Back to Event</a>
        </div>

        <div class="member-required-banner">
            <div class="member-required-title">Fan Girl Football membership is required</div>
            <div class="member-required-text">
                Membership is free and the email you use here must match your Fan Girl Football membership email.
            </div>
            <a class="member-signup-link" href="https://fan-girl-football.mn.co/sign_up" target="_blank">
                Sign up for free membership here →
            </a>
        </div>

        <div class="eyebrow">Championship Draft Weekend</div>
        <h1>Reserve your weekend and choose your league.</h1>
        <p class="subtext">
            Your registration includes a base event ticket, your league entry fee, and processing.
        </p>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="membership-error-box">
                @Model.ErrorMessage
            </div>
        }

        <div class="hero-grid">
            <div class="card">
                <form asp-controller="Events" asp-action="CreateEventStripeCheckout" method="post" id="signupForm">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                    <div class="form-grid">
                        <div class="field">
                            <label asp-for="FirstName"></label>
                            <input asp-for="FirstName" />
                            <span asp-validation-for="FirstName" class="field-validation"></span>
                        </div>

                        <div class="field">
                            <label asp-for="LastName"></label>
                            <input asp-for="LastName" />
                            <span asp-validation-for="LastName" class="field-validation"></span>
                        </div>

                        <div class="field full">
                            <label asp-for="Email"></label>
                            <input asp-for="Email" id="emailField" />
                            <span asp-validation-for="Email" class="field-validation"></span>
                            <div id="membershipValidationMessage" class="membership-validation-message"></div>
                        </div>

                        <div class="field full">
                            <label asp-for="LeagueLevel">Choose Your League</label>

                            <div class="league-options">
                                <label class="league-option @(Model.LeagueLevel == "0" ? "selected" : "")">
                                    <input type="radio" asp-for="LeagueLevel" value="0" />
                                    <div class="league-top">
                                        <span class="league-name">Free Community League</span>
                                        <span class="league-price">Free</span>
                                    </div>
                                    <div class="small">Join the weekend with no league entry fee.</div>
                                </label>

                                <label class="league-option @(Model.LeagueLevel == "25" ? "selected" : "")">
                                    <input type="radio" asp-for="LeagueLevel" value="25" />
                                    <div class="league-top">
                                        <span class="league-name">$25 League</span>
                                        <span class="league-price">$25</span>
                                    </div>
                                    <div class="small">Affordable and fun.</div>
                                </label>

                                <label class="league-option @(Model.LeagueLevel == "50" ? "selected" : "")">
                                    <input type="radio" asp-for="LeagueLevel" value="50" />
                                    <div class="league-top">
                                        <span class="league-name">$50 League</span>
                                        <span class="league-price">$50</span>
                                    </div>
                                    <div class="small">Competitive and more accessible.</div>
                                </label>

                                <label class="league-option @(Model.LeagueLevel == "100" ? "selected" : "")">
                                    <input type="radio" asp-for="LeagueLevel" value="100" />
                                    <div class="league-top">
                                        <span class="league-name">$100 Championship League</span>
                                        <span class="league-price">$100</span>
                                    </div>
                                    <div class="small">Highest prize pool and premium competition level.</div>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="terms-inline">
                        <input asp-for="AgreeToTerms" type="checkbox" id="agreeToTerms" />
                        <label for="agreeToTerms">
                            I agree to the
                            <a href="#" id="openTermsModal" class="terms-link">Terms and Conditions</a>.
                        </label>
                    </div>
                    <span asp-validation-for="AgreeToTerms" class="field-validation"></span>

                    <div id="termsModal" class="terms-modal" aria-hidden="true">
                        <div class="terms-modal-backdrop" id="closeTermsModalBg"></div>
                        <div class="terms-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="termsModalTitle">
                            <button type="button" class="terms-modal-close" id="closeTermsModalBtn" aria-label="Close">×</button>

                            <h3 id="termsModalTitle">Terms and Conditions</h3>

                            <div class="terms-modal-content">
                                <p>
                                    By registering for Championship Draft Weekend, you acknowledge that this event includes live participation,
                                    networking, fantasy football contests, and event photography and video.
                                </p>
                                <p>
                                    All registrations are final unless otherwise stated by Fan Girl Football. League prizes are based on the
                                    selected entry level and will be awarded according to the posted prize structure.
                                </p>
                                <p>
                                    By attending, you grant Fan Girl Football permission to use photos and video taken during the event for
                                    marketing, promotional, editorial, website, social media, and future event materials without additional
                                    compensation.
                                </p>
                                <p>
                                    Fan Girl Football reserves the right to make event updates as needed, including scheduling, format,
                                    and league administration decisions.
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="btn-row">
                        <button type="submit" class="btn btn-primary">Continue to Payment</button>
                        <a href="@Url.Action("ChampionshipDraftWeekend", "Events")" class="btn btn-outline">Back to Event</a>
                    </div>
                </form>
            </div>

            <div>
                <div class="card price-callout">
                    <div class="eyebrow">Current ticket price</div>
                    <div class="price-big">@Model.BaseTicketPrice.ToString("C")</div>
                    <div class="muted">@Model.PricingLabel</div>
                </div>

                <div class="card mt-18">
                    <div class="eyebrow">Order summary</div>

                    <div class="summary-row">
                        <span>Base Weekend Ticket</span>
                        <strong id="summaryBase">@Model.BaseTicketPrice.ToString("C")</strong>
                    </div>

                    <div class="summary-row">
                        <span>League Entry Fee</span>
                        <strong id="summaryLeague">@Model.LeagueFee.ToString("C")</strong>
                    </div>

                    <div class="summary-row">
                        <span>Processing Fee</span>
                        <strong id="summaryFee">@Model.ProcessingFee.ToString("C")</strong>
                    </div>

                    <div class="summary-row summary-total">
                        <span>Total</span>
                        <span id="summaryTotal">@Model.Total.ToString("C")</span>
                    </div>
                </div>

                <div class="prize-box">
                    <h3>League Prize Structure</h3>
                    <div class="prize-tier">
                        <strong>Free Community League</strong>
                        <div>Community bragging rights and a fun weekend competition</div>
                    </div>
                    <div class="prize-tier">
                        <strong>$25 League</strong>
                        <div>1st: $180 | 2nd: $90 | 3rd: $30</div>
                    </div>
                    <div class="prize-tier">
                        <strong>$50 League</strong>
                        <div>1st: $360 | 2nd: $180 | 3rd: $60</div>
                    </div>
                    <div class="prize-tier">
                        <strong>$100 Championship League</strong>
                        <div>1st: $720 | 2nd: $360 | 3rd: $120</div>
                    </div>

                </div>
            </div>
        </div>
    </div>



    <script>
        (function () {
            const baseTicket = @Model.BaseTicketPrice.ToString(System.Globalization.CultureInfo.InvariantCulture);
            const options = document.querySelectorAll('input[name="LeagueLevel"]');
            const labels = document.querySelectorAll('.league-option');
            const summaryLeague = document.getElementById('summaryLeague');
            const summaryFee = document.getElementById('summaryFee');
            const summaryTotal = document.getElementById('summaryTotal');
            const emailField = document.getElementById('emailField');
            const validationMessage = document.getElementById('membershipValidationMessage');
            const form = document.getElementById('signupForm');

            function leagueFeeFromValue(value) {
                switch (value) {
                    case "100": return 100;
                    case "50": return 50;
                    case "25": return 25;
                    case "0": return 0;
                    default: return 100;
                }
            }

            function calcFee(amount) {
                return Math.round(((amount * 0.03) + 0.80) * 100) / 100;
            }

            function formatMoney(value) {
                return new Intl.NumberFormat('en-US', {
                    style: 'currency',
                    currency: 'USD'
                }).format(value);
            }

                let leagueFee = 100;

                options.forEach((option) => {
                    if (option.checked) {
                        leagueFee = leagueFeeFromValue(option.value);
                    }
                });

                labels.forEach((label) => {
                    const radio = label.querySelector('input[type="radio"]');
                    label.classList.toggle('selected', radio.checked);
                });

                const processingFee = calcFee(baseTicket + leagueFee);
                const total = baseTicket + leagueFee + processingFee;

                summaryLeague.textContent = formatMoney(leagueFee);
                summaryFee.textContent = formatMoney(processingFee);
                summaryTotal.textContent = formatMoney(total);
            }

            async function validateMembershipEmail() {
                const email = emailField.value.trim();

                if (!email) {
                    validationMessage.className = 'membership-validation-message error';
                    validationMessage.textContent = 'Please enter your membership email.';
                    return false;
                }

                try {
                    const response = await fetch(`/Events/ValidateMembershipEmail?email=${encodeURIComponent(email)}`);
                    const result = await response.json();

                    if (result.valid) {
                        validationMessage.className = 'membership-validation-message success';
                        validationMessage.textContent = result.message;
                        return true;
                    } else {
                        validationMessage.className = 'membership-validation-message error';
                        validationMessage.textContent = result.message;
                        return false;
                    }
                } catch {
                    validationMessage.className = 'membership-validation-message error';
                    validationMessage.textContent = 'Unable to validate membership email right now. Please try again.';
                    return false;
                }
            }

            options.forEach((option) => {
                option.addEventListener('change', updateSelected);
            });

            emailField.addEventListener('blur', async function () {
                await validateMembershipEmail();
            });

            form.addEventListener('submit', async function (e) {
                const ok = await validateMembershipEmail();
                if (!ok) {
                    e.preventDefault();
                    emailField.focus();
                }
            });

            updateSelected();
        })();
                const openTermsModal = document.getElementById('openTermsModal');
        const termsModal = document.getElementById('termsModal');
        const closeTermsModalBtn = document.getElementById('closeTermsModalBtn');
        const closeTermsModalBg = document.getElementById('closeTermsModalBg');

        function openTerms() {
            termsModal.classList.add('open');
        }

        function closeTerms() {
            termsModal.classList.remove('open');
        }

        openTermsModal.addEventListener('click', function (e) {
            e.preventDefault();
            openTerms();
        });

        closeTermsModalBtn.addEventListener('click', closeTerms);
        closeTermsModalBg.addEventListener('click', closeTerms);

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                closeTerms();
            }
        });
    </script>
</body>
</html>