@{
    Layout = null;
    ViewData["Title"] = "Championship Draft Weekend";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/championship-draft-weekend.css" asp-append-version="true" />
</head>
<body>

<section class="cdw-hero">
    <div class="cdw-container">
        <div class="cdw-topbar">
            <div class="cdw-brand">
                    <div><img src="~/img/logo/eventlogowhite.png" style="max-height: 200px" /></div>
                
            </div>

            <div class="cdw-top-actions">
                <a href="#sponsor" class="cdw-btn cdw-btn-primary">Sign Up Now</a>
            </div>
        </div>

        <div class="cdw-hero-grid">
            <div class="cdw-hero-copy">
                <div class="cdw-badge">Aug 21–22, 2026</div>

                <h1>
                    Where fantasy football becomes a weekend of
                    <span>connection, competition, and fun.</span>
                </h1>

                <p class="cdw-hero-text">
                    Championship Draft Weekend is a premium women’s fantasy football experience
                    built around live drafting, networking, and unforgettable shared moments.
                </p>

                <div class="cdw-hero-actions">
                    <a href="#weekend" class="cdw-btn cdw-btn-light">Explore the Weekend</a>
                    <a href="#sponsor" class="cdw-btn cdw-btn-outline">Become a Sponsor</a>
                </div>

                <div class="cdw-stat-grid">
                    <div class="cdw-stat-card">
                        <div class="cdw-stat-label">When</div>
                        <div class="cdw-stat-value">Aug 21–22</div>
                    </div>
                    <div class="cdw-stat-card">
                        <div class="cdw-stat-label">Community</div>
                        <div class="cdw-stat-value">1,500+ Women</div>
                    </div>
                    <div class="cdw-stat-card">
                        <div class="cdw-stat-label">Focus</div>
                        <div class="cdw-stat-value">Networking</div>
                    </div>
                </div>
            </div>

           
                <div class="cdw-hero-visual">
                    <div class="cdw-hero-image-card">
                        <div class="cdw-hero-video">
                            <img src="~/img/events/championship-draft-weekend-promo.png" alt="Championship Draft Weekend promo" />
                        </div>

                        <div class="cdw-video-gradient"></div>

                        <div class="cdw-hero-overlay-card cdw-hero-overlay-top">
                            <div class="cdw-overlay-label">Friday</div>
                            <div class="cdw-overlay-title">Network & Meet</div>
                            <p>Stylish, social, welcoming, and built for connection.</p>
                        </div>

                        <div class="cdw-hero-overlay-card cdw-hero-overlay-bottom">
                            <div class="cdw-overlay-label gold">Saturday</div>
                            <div class="cdw-overlay-title">Live Draft Experience</div>
                            <p>A high-energy fantasy football draft built around community and competition.</p>
                        </div>
                    </div>
                </div>
        
        </div>
    </div>
</section>

<section id="weekend" class="cdw-section">
    <div class="cdw-container">
        <div class="cdw-section-heading">
            <div class="cdw-eyebrow">Why this weekend matters</div>
            <h2>A football event built around women, community, and connection.</h2>
        </div>

        <div class="cdw-feature-grid">
            <div class="cdw-feature-card">
                <h3>Friday Networking</h3>
                <p>
                    Kick off the weekend with a social meet-and-greet designed to spark new connections
                    and bring women together through football.
                </p>
            </div>

            <div class="cdw-feature-card">
                <h3>Saturday Live Draft</h3>
                <p>
                    An elevated fantasy football draft experience that blends strategy, energy,
                    and unforgettable shared moments.
                </p>
            </div>

            <div class="cdw-feature-card">
                <h3>Curated Experience</h3>
                <p>
                    Built to feel premium, welcoming, and fun — where football, friendship,
                    and community meet.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="cdw-section cdw-section-light">
    <div class="cdw-container">
        <div class="cdw-audience-grid">
            <div class="cdw-audience-copy">
                <div class="cdw-eyebrow purple">Who’s coming</div>
                <h2>Active. Social. Connected.</h2>

                <p class="cdw-section-text">
                    Women who love football, thrive in community, and show up for both the competition
                    and the experience.
                </p>

                <div class="cdw-traits-grid">
                    <div class="cdw-trait-card">Confident &amp; Curious</div>
                    <div class="cdw-trait-card">Social by Nature</div>
                    <div class="cdw-trait-card">Competitive &amp; Engaged</div>
                    <div class="cdw-trait-card">Connection-Driven</div>
                </div>

                <div class="cdw-callout">
                    <div class="cdw-callout-big">1,500+ Women</div>
                    <p>
                        A growing community actively participating in fantasy football and shared experiences.
                    </p>
                </div>
            </div>

            <div class="cdw-audience-images">
                <div class="cdw-image-stack cdw-image-stack-one">
                    <img src="~/images/women-drafting.jpg" alt="Women drafting fantasy football teams" />
                </div>
                <div class="cdw-image-stack cdw-image-stack-two">
                    <img src="~/images/women-watching-football.jpg" alt="Women watching football together" />
                </div>
            </div>
        </div>
    </div>
</section>

<section id="sponsor" class="cdw-section">
    <div class="cdw-container">
        <div class="cdw-sponsor-header">
            <div>
                <div class="cdw-eyebrow">Sponsor the event</div>
                <h2>Partnership opportunities designed for visibility, alignment, and engagement.</h2>
            </div>

            <a href="mailto:youremail@domain.com?subject=Championship%20Draft%20Weekend%20Sponsorship" class="cdw-btn cdw-btn-primary">
                Request Sponsorship Details
            </a>
        </div>

        <div class="cdw-package-grid">
            <div class="cdw-package-card">
                <div class="cdw-package-name">Premier Partner</div>
                <div class="cdw-package-price">$5,000</div>
                <p>
                    Own the weekend with top-tier branding, pre-event promotion, and premium visibility
                    throughout the experience.
                </p>
                <ul>
                    <li>Presenting partner recognition</li>
                    <li>Featured social + email promotion</li>
                    <li>Premium onsite branding</li>
                </ul>
            </div>

            <div class="cdw-package-card">
                <div class="cdw-package-name">Experience Partner</div>
                <div class="cdw-package-price">$2,500–$3,500</div>
                <p>
                    Sponsor a signature moment like the Friday networking event, champagne experience,
                    or live draft environment.
                </p>
                <ul>
                    <li>Moment-based branding</li>
                    <li>Event integration</li>
                    <li>Audience-facing visibility</li>
                </ul>
            </div>

            <div class="cdw-package-card">
                <div class="cdw-package-name">Supporting Partner</div>
                <div class="cdw-package-price">$1,000–$1,500</div>
                <p>
                    Be part of the overall event experience with strong visibility and meaningful audience alignment.
                </p>
                <ul>
                    <li>Logo presence</li>
                    <li>Social mentions</li>
                    <li>Onsite exposure</li>
                </ul>
            </div>

            <div class="cdw-package-card">
                <div class="cdw-package-name">In-Kind Partner</div>
                <div class="cdw-package-price">Product / Swag</div>
                <p>
                    Put your brand directly in attendees’ hands through giveaways, curated swag,
                    or product integration.
                </p>
                <ul>
                    <li>Swag bag inclusion</li>
                    <li>Product spotlight</li>
                    <li>Community exposure</li>
                </ul>
            </div>
        </div>

        <div class="cdw-strategy-grid">
            <div class="cdw-strategy-card">
                <div class="cdw-eyebrow">Strategic sponsorship opportunity</div>

                <div class="cdw-strategy-columns">
                    <div>
                        <h3>Reach</h3>
                        <p>
                            Tap into a high-energy, engaged audience of women actively participating
                            in fantasy football and live experiences.
                        </p>
                    </div>

                    <div>
                        <h3>Branding</h3>
                        <p>
                            Align with a fast-growing audience at the intersection of sports,
                            lifestyle, and community.
                        </p>
                    </div>

                    <div>
                        <h3>Engagement</h3>
                        <p>
                            Be part of the experience through immersive moments that create real
                            connection and lasting brand impact.
                        </p>
                    </div>
                </div>
            </div>

            <div class="cdw-cta-card">
                <div class="cdw-eyebrow">Let’s partner</div>
                <h3>Put your brand in the middle of the moment.</h3>
                <p>
                    Join us in redefining fantasy football for women—through connection, community,
                    and experience.
                </p>

                <ul class="cdw-cta-list">
                    <li>Social + email promotion</li>
                    <li>Onsite branding + integration</li>
                    <li>Community exposure before, during, and after the event</li>
                </ul>

                <a href="mailto:youremail@domain.com?subject=Championship%20Draft%20Weekend%20Sponsorship" class="cdw-btn cdw-btn-light">
                    Become a Sponsor
                </a>
            </div>
        </div>
    </div>
</section>

<section class="cdw-footer-cta">
    <div class="cdw-container cdw-footer-grid">
        <div>
            <h2>Championship Draft Weekend</h2>
            <p>
                A premium fantasy football experience where women connect, compete, and belong.
            </p>
        </div>

        <div class="cdw-footer-actions">
            <a href="#" class="cdw-btn cdw-btn-primary">Join the Weekend</a>
            <a href="#sponsor" class="cdw-btn cdw-btn-outline">Sponsor the Event</a>
        </div>
    </div>
</section>
</body>
</html>