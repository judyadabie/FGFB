@page "/Articles"
@model FGFB.Pages.ArticlesModel
@{
}
<body>
 
    <!-- header area start -->

    <header>
        <div id="header-sticky" class="header__area header__transparent header__padding">
            <div class="container-fluid">
                <div class="row align-items-center">
                    <div class="col-xxl-3 col-xl-3 col-lg-4 col-md-2 col-sm-4 col-6">
                        <div class="header__left d-flex">
                            <div class="logo">
                                <a href="index" rel="nofollow">
                                    <img id="FGFBLogo" src="/img/logo/FGFLogoNewFont.png" alt="logo">
                                </a>
                            </div>

                        </div>
                    </div>
                    <div class="col-xxl-9 col-xl-9 col-lg-8 col-md-10 col-sm-8 col-6">
                        <div class="header__right d-flex justify-content-end align-items-center">
                            <div class="main-menu">
                                <nav id="mobile-menu">
                                    <ul>
                                        <li>
                                            <a href="index" rel="nofollow">Home</a>
                                        </li>
                                        <li>
                                            <a href="https://fan-girl-football.mn.co/sign_in">Login</a>

                                        </li>
                                        <li>
                                            <a href="https://shop.fangirlfootball.com/" target="_blank">Shop FanGirl</a>

                                        </li>
                                        <li>
                                            <a href="Articles">Articles</a>

                                        </li>
                                        <li>
                                            <a href="About">About</a>

                                        </li>
                                        <li>
                                            <a href="https://www.youtube.com/&#64FanGirlFootball" target="YouTube">YouTube</a>

                                        </li>
                                        <li><a href="FantasyFootballBook">Get the Book</a></li>
                                        <li><a href="contact">Contact</a></li>
                                    </ul>
                                </nav>
                            </div>

                            <div class="header__btn ml-20 d-none d-sm-block">
                                <a href="https://fan-girl-football.mn.co/sign_up" class="e-btn">Join Now - FREE!</a>
                            </div>
                            <div class="sidebar__menu d-xl-none">
                                <div class="sidebar-toggle-btn ml-30" id="sidebar-toggle">
                                    <span class="line"></span>
                                    <span class="line"></span>
                                    <span class="line"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- header area end -->
    <!-- sidebar area start -->
    <div class="sidebar__area">
        <div class="sidebar__wrapper">
            <div class="sidebar__close">
                <button class="sidebar__close-btn" id="sidebar__close-btn">
                    <span><i class="fal fa-times"></i></span>
                    <span>close</span>
                </button>
            </div>
            <div class="sidebar__content">
                <div class="logo mb-40">
                    <a href="index" rel="nofollow">
                        <img src="/img/logo/FGFBLogo150.png" alt="logo">
                    </a>
                </div>
                <div class="mobile-menu fix"></div>



            </div>
        </div>
    </div>
    <!-- sidebar area end -->
    <div class="body-overlay"></div>
    <!-- sidebar area end -->

    <main>

        <!-- blog area start -->
        <section class="blog__area pt-120 pb-120">
            <div class="container">

                @if (Model.Items != null && Model.Items.Count > 0)
                {
                    var featuredItem = Model.Items[0];
                    var featuredFields = featuredItem.Fields;

                    var featuredSlug = featuredFields?.Slug ?? "";
                    var featuredTitle = featuredFields?.Title ?? "";
                    var featuredAuthorId = featuredFields?.Author?.Sys?.Id;
                    var featuredImageId = featuredFields?.HeaderImage?.Sys?.Id ?? featuredFields?.Thumbnail?.Sys?.Id;

                    var featuredAuthor = Model.Includes?.Entry?
                    .FirstOrDefault(x => x.Sys?.Id == featuredAuthorId);

                    var featuredAuthorName = featuredAuthor?.Fields?.Name ?? "Unknown";

                    var featuredImage = Model.Includes?.Asset?
                    .FirstOrDefault(a => a.Sys?.Id == featuredImageId);

                    var featuredImageUrl = featuredImage?.Fields?.File?.Url != null
                    ? $"https:{featuredImage.Fields.File.Url}"
                    : "/img/blog/tile/default.png";

                    var featuredDate = featuredItem.Sys?.CreatedAt?.ToString("MMMM dd, yyyy");

                    <!-- Featured Article -->
                    <div class="row mb-50">
                        <div class="col-12">
                            <a href="/Articles/@featuredSlug" class="blog__card-link">
                                <div class="blog__featured-card">

                                    <div class="blog__featured-image-wrap">
                                        <img src="@featuredImageUrl" alt="@featuredTitle" class="blog__featured-image" />

                                        <!-- Overlay -->
                                        <div class="blog__featured-overlay">
                                            <div class="blog__featured-badge">
                                                FEATURED
                                            </div>

                                            <h2 class="blog__featured-title">
                                                @featuredTitle
                                            </h2>

                                            <div class="blog__meta d-flex align-items-center justify-content-between flex-wrap text-white">
                                                <span>@featuredAuthorName</span>
                                                <span>@featuredDate</span>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </a>
                        </div>
                    </div>

                    <!-- Remaining Articles -->
                    @if (Model.Items.Count > 1)
                    {
                        <div class="row">
                            @for (int i = 1; i < Model.Items.Count; i++)
                            {
                                var item = Model.Items[i];
                                var fields = item.Fields;

                                var slug = fields?.Slug ?? "";
                                var title = fields?.Title ?? "";
                                var authorId = fields?.Author?.Sys?.Id;
                                var imageId = fields?.Thumbnail?.Sys?.Id ?? fields?.HeaderImage?.Sys?.Id;

                                var author = Model.Includes?.Entry?
                                .FirstOrDefault(x => x.Sys?.Id == authorId);

                                var authorName = author?.Fields?.Name ?? "Unknown";

                                var image = Model.Includes?.Asset?
                                .FirstOrDefault(a => a.Sys?.Id == imageId);

                                var imageUrl = image?.Fields?.File?.Url != null
                                ? $"https:{image.Fields.File.Url}"
                                : "/img/blog/tile/default.png";

                                var createdDate = item.Sys?.CreatedAt?.ToString("MMMM dd, yyyy");

                                <div class="col-xxl-4 col-xl-4 col-lg-4 col-md-6 mb-30">
                                    <a href="/Articles/@slug" class="blog__card-link">
                                        <div class="blog__wrapper h-100">
                                            <div class="blog__item white-bg transition-3 fix h-100 blog__tile-card">

                                                <div class="blog__thumb w-img fix blog__tile-image-wrap">
                                                    <img src="@imageUrl" alt="@title" class="blog__tile-image">
                                                </div>

                                                <div class="blog__content d-flex flex-column">
                                                    <div class="blog__tag">
                                                        <span>Fantasy Football</span>
                                                    </div>

                                                    <h3 class="blog__title">
                                                        @title
                                                    </h3>

                                                    <div class="blog__meta d-flex align-items-center justify-content-between mt-auto">
                                                        <div class="blog__author d-flex align-items-center">
                                                            <div class="blog__author-info">
                                                                <h5>@authorName</h5>
                                                            </div>
                                                        </div>

                                                        <div class="blog__date d-flex align-items-center">
                                                            <i class="fal fa-clock"></i>
                                                            <span>@createdDate</span>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>
                                    </a>
                                </div>
                            }
                        </div>
                    }
                }

            </div>
        </section>
        <!-- blog area end -->

    </main>

    <style>
        /* FEATURED CARD - FULL BLEED IMAGE STYLE */
        .blog__featured-card {
            position: relative;
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 10px 28px rgba(0,0,0,0.15);
        }

        .blog__featured-image-wrap {
            position: relative;
            height: 480px;
        }

        .blog__featured-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* DARK GRADIENT OVERLAY */
        .blog__featured-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 40px;
            background: linear-gradient(to top, rgba(0,0,0,0.75), rgba(0,0,0,0.1));
        }

        /* FEATURED BADGE */
        .blog__featured-badge {
            display: inline-block;
            background: #ff3b3b;
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            padding: 6px 12px;
            border-radius: 20px;
            margin-bottom: 15px;
            letter-spacing: 1px;
        }

        /* BIG TITLE */
        .blog__featured-title {
            font-size: 40px;
            line-height: 1.2;
            color: #fff;
            margin-bottom: 15px;
        }

        /* REMOVE TAG FROM NORMAL CARDS */
        .blog__tag {
            display: none;
        }
    </style>

