@page
@model FGFB.Pages.Contest.ContestStandingsModel
@{
}
<div>

    <img src="/img/logo/FGFLogoNewFont.png" />
</div>
<main>

    <section class="blog__area">
        <div class="container">
            
<h1 class="contest-header">Contest Standings Final</h1>
                            <table class="contestdetails-table">
    <thead>
                                <td style=" font-weight:600;padding-right:5px; padding-left:10px;">Rank</td>
                                <td style=" font-weight:600;text-align:left; padding-left:10px;">Entry Name</td>
                                <td style=" font-weight:600;text-align:right; padding-left:10px;">Season Total Score</td>
                                <td style=" font-weight:600;text-align:right; padding-left:10px;">PlayOff WK 14</td>
                                <td style=" font-weight:600;text-align:right; padding-left:10px;">PlayOff WK 15</td>
                                <td style=" font-weight:600;text-align:right; padding-left:10px;">Finals Wk 16 & 17</td>
                                <td style="text-align: right; font-weight:600; padding-left:10px;">Entry Status</td></thead>

                       
        </div>
        </section>
@{

    foreach(FGFB.Models.StandingRow sRow in Model.standings)
    {
            <tr onclick="location.href = 'EntryDetails?entryid=@sRow.EntryId&entryName=@sRow.EntryName&rank=@sRow.currentRank&status=@sRow.status'"><td>@sRow.currentRank</td><td style="text-decoration-line:underline; color:#671e75;">@sRow.EntryName</td><td style="text-align: right;">@sRow.SeasonScore</td><td style="text-align: right;">@sRow.PlayOffWeek1</td><td style="text-align: right;">@sRow.PlayOffWeek2</td><td style="text-align: right;">@sRow.FinalsScore</td><td style="text-align: right; padding-left:5px;">@sRow.status</td></tr>
    }
}

</table>

