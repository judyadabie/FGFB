@page
@model FGFB.Pages.Contest.EntryDetailsModelPS
@{
}
<div>

    <img src="/img/logo/FGFLogoNewFont.png" />
</div>
<main>

    <section class="blog__area">
        <div class="container">

               
                            <h3><a href="~/Contest/ContestStandingsPS" class="contest-link" style="text-decoration-line: underline;hover ">Full Standings</a></h3>
                            <h1 class="contest-header">Entry Details</h1>
                            <table>
                                <tr><td><h4>Entry Name: @Model.entry.name</h4></td><td style="text-align:right;width:50%;"><h4>Total Score: @Model.entry.totalScore</h4></td></tr>
                                <tr><td style="text-align:left;width:50%;"><h4>Ranking: @Model.entry.currentRank</h4></td><td style="text-align:right;width:50%;"><h4></h4></td></tr>

                            </table>
                            
                            <table class="contestdetails-table">
                                <thead>
                                <td style="text-align:left;"><b>Player</b></td>
                                <td style="text-align:left; font-weight:600;"><b>Tier</b></td>
                                <td style="text-align:right; font-weight:600;"><b>Wildcard</b></td>
                                <td style="text-align:right; font-weight:600;"><b>Divisional</b></td>
                                <td style="text-align:right; font-weight:600;"><b>Championship</b></td>
                                <td style="text-align:right; font-weight:600;"><b>Super Bowl</b></td>
                                </thead>

            
        </div>
    </section>
    @{
        decimal totalwk1 = 0;
        decimal totalwk2 = 0;
        decimal totalwk3 = 0;
        decimal totalwk4 = 0;
        
        foreach (FGFB.Models.Player player in Model.entry.team)
        {
            <tr>@if (player.rookie)
                {
                    <td>@player.playerName *</td>
                }
                else
                {
                    <td>@player.playerName </td>
                }
                <td>@player.Tier</td>
                @if(player.WeeklyScores.Exists(n => n.week == 19))
                {
                    if(player.WeeklyScores.Find(n => n.week == 19).winner){
                        <td style="text-align:right; background-color:yellow;">@player.WeeklyScores.Find(f => f.week == 19).totalScore</td>
                        totalwk1 += @player.WeeklyScores.Find(f => f.week == 19).totalScore;
                    }
                    else
                    {
                        <td style="text-align:right">@player.WeeklyScores.Find(f => f.week == 19).totalScore</td>
                    }
                }
                else
                {
                    <td style="text-align:right"> </td>
                }

                @if (player.WeeklyScores.Exists(n => n.week == 20))
                {
                    if (player.WeeklyScores.Find(n => n.week == 20).winner)
                    {
                        <td style="text-align:right; background-color:yellow;">@player.WeeklyScores.Find(f => f.week == 20).totalScore</td>
                        totalwk2 += @player.WeeklyScores.Find(f => f.week == 20).totalScore;
                    }
                    else
                    {
                        <td style="text-align:right">@player.WeeklyScores.Find(f => f.week == 20).totalScore</td>
                    }
                }
                else{
                    <td style ="text-align:right"> </td>
                }
                    

                @if (player.WeeklyScores.Exists(n => n.week == 21))
                {
                    if (player.WeeklyScores.Find(n => n.week == 21).winner)
                    {
                        <td style="text-align:right; background-color:yellow;">@player.WeeklyScores.Find(f => f.week == 21).totalScore</td>
                        totalwk3 += @player.WeeklyScores.Find(f => f.week == 21).totalScore;
                    }
                    else
                    {
                        <td style="text-align:right">@player.WeeklyScores.Find(f => f.week == 21).totalScore</td>
                    }
                }
                else{
                    <td style ="text-align:right"> </td>
                }

                @if (player.WeeklyScores.Exists(n => n.week == 22))
                {
                    if (player.WeeklyScores.Find(n => n.week == 22).winner)
                    {
                        <td style="text-align:right; background-color:yellow;">@player.WeeklyScores.Find(f => f.week == 22).totalScore</td>
                        totalwk4 += @player.WeeklyScores.Find(f => f.week == 22).totalScore;
                    }
                    else
                    {
                        <td style="text-align:right">@player.WeeklyScores.Find(f => f.week == 22).totalScore</td>
                    }
                }
                else
                {
                    <td style="text-align:right"> </td>
                }
                
                    </tr>
               @if(player.Tier.EndsWith("3"))
            {
                <tr><td colspan="@(Model.entry.CurrentWeek + 2)" style="border-bottom:solid;"></td></tr>
            }
        }
    }
    <tr>
        <td></td>
        <td></td>
        <td style="text-align:right">@totalwk1</td>
        <td style="text-align:right">@totalwk2</td>
        <td style="text-align:right">@totalwk3</td>
        <td style="text-align:right">@totalwk4</td>
    </tr>
    </table>
    
    <h4>Yellow highlighted scores are the ones that we counted for the week.</h4>
</main>

